pipeline {
    agent any

    environment {
        IMAGE_NAME = "mahe07/spring-petclinic"
        IMAGE_TAG  = "latest"
        AWS_REGION = 'ap-south-2'
        AWS_ACCOUNT_ID = '063562647032'
        ECR_REPOSITORY = 'self/springboot-app'
        DOCKERHUB_IMAGE = 'mahe07/spring-petclinic:latest'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                 url:'https://github.com/Mahendra-GH/spring-petclinic.git'
            }
        }

        stage('Build Jar') {
            steps {
                sh './mvnw clean package -DskipTests'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh ' docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'mahe07',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker logout
                    '''
                }
            }
        }
        stage('Push Docker Image to Amazon ECR') {

            steps {
                sh '''
                    # Login to Amazon ECR
                    aws ecr get-login-password --region $AWS_REGION | \
                    docker login --username AWS \
                    --password-stdin $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com

                    # Pull image from Docker Hub
                    docker pull $DOCKERHUB_IMAGE

                    # Tag image for ECR
                    docker tag $DOCKERHUB_IMAGE \
                    $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPOSITORY:$IMAGE_TAG

                    # Push image to ECR
                    docker push \
                    $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPOSITORY:$IMAGE_TAG
                '''
            }
        }
    }
            

    post {
        success {
            echo 'Docker image pushed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}

